{
  "name": "mail-telegram-bot",
  "version": "1.0.0",
  "description": "Mail to Telegram notification system for store security",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/db',{recursive:true});fs.copyFileSync('src/db/schema.sql','dist/db/schema.sql');console.log('schema.sql copied to dist/db/')\"",
    "start": "node ./index.js",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production",
    "stop:pm2": "pm2 stop mail-telegram-bot",
    "logs:pm2": "pm2 logs mail-telegram-bot",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "jest"
  },
  "dependencies": {
    "node-sqlite3-wasm": "^0.8.20",
    "express": "^4.18.3",
    "grammy": "^1.21.2",
    "imapflow": "^1.0.162",
    "mailparser": "^3.7.1",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/mailparser": "^3.4.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2"
  }
}
